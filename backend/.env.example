# Copy to .env and fill in. Required for: docker compose (env_file), local dev.
# Database – override in Docker via compose; used for local dev.

# Database connection
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/ecommerce"
ACCESS_TOKEN_SECRET="youraccesstokensecret"
REFRESH_TOKEN_SECRET="yourrefreshtokensecret"
RECAPTCHA_SECRET_KEY=

# Password reset – link base (frontend URL) and SMTP (Gmail example)
RESET_LINK_BASE_URL="http://localhost:3000"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google OAuth – credentials and redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/oauth/google/callback
